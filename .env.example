# IP address of your Ubuntu machine (accessible from Mac)
HOST_IP=192.168.1.100

# Port ranges (ensure these are open in your firewall)
# noVNC ports: NOVNC_PORT_START to NOVNC_PORT_START + MAX_EMULATORS - 1
NOVNC_PORT_START=6080

# ADB ports: ADB_PORT_START, ADB_PORT_START+2, ADB_PORT_START+4, ...
ADB_PORT_START=5554

# Maximum number of simultaneous emulators
MAX_EMULATORS=5
